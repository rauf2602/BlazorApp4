@inherits LayoutComponentBase

<div class="page @(isDark ? "dm" : "")">
    <div class="mobile-header">
        <button class="hamburger" onclick="toggleSidebar()">☰</button>
        <span class="mobile-title">Store Manager</span>
        <button id="themeToggleMob" class="theme-btn @(isDark ? "active" : "")" onclick="window.toggleDarkMode()">
            <svg class="icon sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
    </div>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <NavMenu />
    <main>
        <div class="top-bar">
            <button id="themeToggle" class="theme-btn @(isDark ? "active" : "")" onclick="window.toggleDarkMode()">
                <svg class="icon sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <svg class="icon moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
        </div>
        <article class="content">@Body</article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<script>
    function toggleSidebar() {
        document.getElementById('sidebarOverlay').classList.toggle('show');
        document.querySelector('.sidebar').classList.toggle('show');
    }
    window.toggleDarkMode = function() {
        const isDark = document.querySelector('.page').classList.toggle('dm');
        document.documentElement.classList.toggle('dm', isDark);
        document.querySelectorAll('.theme-btn').forEach(b => b.classList.toggle('active', isDark));
        localStorage.setItem('dm', isDark ? '1' : '0');
    };
    document.addEventListener('DOMContentLoaded', () => {
        if (localStorage.getItem('dm') === '1') window.toggleDarkMode();
    });
</script>

<style>
    .page { min-height: 100vh; background: #f8fafc; color: #0f172a; transition: background .4s, color .4s; }
    .page.dm { background: #0f172a; color: #e2e8f0; }
    main { margin-left: 250px; padding: 24px; min-height: 100vh; overflow-y: auto; }
    .top-bar { display: flex; justify-content: flex-end; margin-bottom: 16px; }

    .mobile-header { display: none; }
    .sidebar-overlay { display: none; }

    .theme-btn {
        width: 48px; height: 48px; border: none; border-radius: 14px; cursor: pointer;
        position: relative; overflow: hidden; background: #ffffff;
        box-shadow: 0 2px 10px rgba(0,0,0,.08), 0 0 0 1px rgba(0,0,0,.05);
        transition: all .3s ease; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .theme-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.12), 0 0 0 1px rgba(0,0,0,.05); }
    .theme-btn:active { transform: translateY(0) scale(.95); }
    .theme-btn.active { background: linear-gradient(135deg, #1e1b4b, #312e81); box-shadow: 0 4px 16px rgba(99,102,241,.3), 0 0 0 1px rgba(99,102,241,.2); }
    .theme-btn .icon { width: 22px; height: 22px; position: absolute; transition: all .4s cubic-bezier(.4,0,.2,1); }
    .theme-btn .sun { color: #f59e0b; opacity: 1; transform: rotate(0deg) scale(1); }
    .theme-btn .moon { color: #e0e7ff; opacity: 0; transform: rotate(-90deg) scale(0); }
    .theme-btn.active .sun { opacity: 0; transform: rotate(90deg) scale(0); }
    .theme-btn.active .moon { opacity: 1; transform: rotate(0deg) scale(1); }

    .content { max-width: 1400px; margin: 0 auto; }
    #blazor-error-ui { display: none; }

    @@media (max-width: 768px) {
        main { margin-left: 0; padding: 12px; padding-top: 60px; }
        .top-bar { display: none; }
        .mobile-header {
            display: flex; align-items: center; gap: 12px;
            position: fixed; top: 0; left: 0; right: 0; z-index: 200;
            background: #f8fafc; padding: 8px 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            height: 52px;
        }
        .page.dm .mobile-header { background: #0f172a; box-shadow: 0 2px 8px rgba(0,0,0,.3); }
        .hamburger {
            font-size: 1.5rem; background: none; border: none; cursor: pointer;
            padding: 4px 8px; color: #0f172a; line-height: 1;
        }
        .page.dm .hamburger { color: #e2e8f0; }
        .mobile-title { flex: 1; font-weight: 700; font-size: 1rem; color: #0f172a; }
        .page.dm .mobile-title { color: #e2e8f0; }
        .mobile-header .theme-btn { width: 36px; height: 36px; border-radius: 10px; }
        .mobile-header .theme-btn .icon { width: 16px; height: 16px; }

        .sidebar-overlay {
            display: block; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,.5); z-index: 98; opacity: 0; pointer-events: none;
            transition: opacity .3s ease;
        }
        .sidebar-overlay.show { opacity: 1; pointer-events: auto; }
    }

    @@media (min-width: 769px) {
        #themeToggleMob { display: none; }
    }
</style>

@code {
    private bool isDark;
}
