        .inventory-table { font-size: .7rem !important; }
        .inventory-table th, .inventory-table td { padding: 4px 3px !important; }
        .inventory-table .btn-sm { padding: 2px 5px !important; font-size: .65rem !important; }
        .history-shell { padding: 10px !important; border-radius: 12px !important; }
        .history-header { flex-direction: column !important; gap: 6px !important; }
        .history-header h3 { font-size: .9rem !important; }
        .history-filters { flex-direction: column !important; gap: 6px !important; }
        .history-search, .history-filter { width: 100% !important; font-size: .8rem !important; padding: 6px 8px !important; }
        .history-table { font-size: .65rem !important; }
        .history-table th, .history-table td { padding: 3px !important; }
        .history-table-wrapper { overflow-x: auto !important; }
        .action-badge { font-size: .55rem !important; padding: 1px 4px !important; }
        .qr-grid { grid-template-columns: repeat(2, 1fr) !important; gap: 8px !important; }
        .qr-card { padding: 8px !important; }
        .qr-card img { width: 80px !important; height: 80px !important; }
        .qr-card .product-name { font-size: .7rem !important; }
        .qr-card .product-price { font-size: .65rem !important; }
        .modal-content { margin: 10px !important; padding: 16px !important; border-radius: 16px !important; }
        .modal-title { font-size: 1rem !important; }
        .modal-body { font-size: .85rem !important; }
        .modal-body input, .modal-body select { font-size: .85rem !important; padding: 8px !important; }
        .modal-actions { flex-direction: column !important; gap: 6px !important; }
        .modal-actions .btn { width: 100% !important; font-size: .8rem !important; padding: 8px !important; }
        .error-message, .success-message { font-size: .8rem !important; padding: 8px !important; }
    }

    /* History Panel */
    .history-shell {
        max-width: 1200px;
        background: var(--card, #fff);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 8px 30px rgba(0,0,0,.08);
        margin-bottom: 32px;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .history-header h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text, #0f172a);
        margin: 0;
    }

    .history-filters {
        display: flex;
        gap: 8px;
    }

