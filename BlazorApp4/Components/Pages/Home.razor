        transition: background 0.25s ease, box-shadow 0.25s ease;
    }

    .inventory-table thead th {
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        color: #0f172a;
        border-bottom: 1px solid rgba(148, 163, 184, 0.18);
