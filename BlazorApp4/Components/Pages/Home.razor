        background: rgba(120, 53, 15, 0.3) !important;
    }

    html.dm .low-stock {
        color: #fbbf24;
    }

    .manager-shell {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.72));
        border: 1px solid rgba(148, 163, 184, 0.14);
        border-radius: 28px;
        padding: 30px 24px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
        backdrop-filter: blur(14px);
        transition: background 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .action-bar .btn {
        width: 130px;
    }

    .btn-sm {
        width: auto;
        min-width: 78px;
    }

    .animated-btn {
        border: 0;
        border-radius: 14px;
        font-weight: 700;
        letter-spacing: 0.02em;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            filter 0.2s ease,
            background-color 0.2s ease;
        animation: buttonFloat 0.55s ease both;
    }

    .animated-btn:hover {
        transform: translateY(-3px) scale(1.02);
        filter: brightness(1.06);
    }

    .animated-btn:active {
        transform: translateY(0) scale(0.98);
    }

    .animated-btn:disabled {
        opacity: 0.45;
        transform: none;
        box-shadow: none;
    }

    .glow-green {
        box-shadow: 0 14px 28px rgba(34, 197, 94, 0.28);
    }

    .glow-red {
        box-shadow: 0 14px 28px rgba(239, 68, 68, 0.28);
    }

    .glow-slate {
        box-shadow: 0 14px 28px rgba(71, 85, 105, 0.32);
    }

    .glow-cyan {
        box-shadow: 0 10px 22px rgba(6, 182, 212, 0.3);
    }

    .glow-amber {
        box-shadow: 0 10px 22px rgba(245, 158, 11, 0.3);
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .inventory-table {
        border-collapse: separate;
