        border-color: rgba(148, 163, 184, 0.12);
        padding: 14px 12px;
        transition: background 0.25s ease, color 0.25s ease;
    }

    .inventory-table tbody tr:hover td {
        background: rgba(241, 245, 249, 0.95);
    }

    .badge.bg-success {
        background: linear-gradient(135deg, #22c55e, #15803d) !important;
        box-shadow: 0 10px 20px rgba(34, 197, 94, 0.22);
    }

    .qr-image {
        width: 160px;
        height: 160px;
        object-fit: contain;
    }

    .qr-preview-card {
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 16px;
        padding: 20px;
        background: linear-gradient(180deg, #ffffff, #f8fafc);
        color: #1e293b;
        transition: background 0.25s ease, color 0.25s ease;
    }

    .print-area {
        display: none;
    }

    .modal-overlay {
        background: rgba(2, 6, 23, 0.72);
        backdrop-filter: blur(8px);
    }

    .modal-content {
        background: linear-gradient(180deg, #ffffff, #f8fafc);
        color: #1e293b;
        border: 1px solid rgba(148, 163, 184, 0.16);
        border-radius: 24px;
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
        transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    }

    .modal-header,
    .modal-footer {
        border-color: rgba(148, 163, 184, 0.12);
    }

    .form-control {
        background: rgba(255, 255, 255, 0.95);
        color: #1e293b;
        border: 1px solid rgba(148, 163, 184, 0.22);
        border-radius: 14px;
        transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    }

    .form-control::placeholder {
        color: #94a3b8;
    }

    .form-control:focus {
        background: #ffffff;
        color: #0f172a;
        border-color: #38bdf8;
        box-shadow: 0 0 0 0.18rem rgba(56, 189, 248, 0.15);
    }

    .form-label {
        color: #475569;
        transition: color 0.25s ease;
    }

    html.dm h2 {
        color: #e2e8f0;
    }

    html.dm .manager-shell {
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.88), rgba(15, 23, 42, 0.78));
        border-color: rgba(148, 163, 184, 0.2);
        box-shadow: 0 24px 60px rgba(2, 8, 23, 0.45);
    }

    html.dm .inventory-table {
        background: rgba(15, 23, 42, 0.68);
        box-shadow: 0 18px 44px rgba(2, 8, 23, 0.35);
    }

    html.dm .inventory-table thead th {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        color: #dbeafe;
    }

    html.dm .inventory-table tbody td {
        background: rgba(15, 23, 42, 0.9);
        color: #dbe4f0;
    }

    html.dm .inventory-table tbody tr:hover td {
        background: rgba(30, 41, 59, 0.96);
    }

    html.dm .qr-preview-card {
        background: linear-gradient(180deg, #111827, #0f172a);
        color: #e2e8f0;
    }

    html.dm .modal-content {
        background: linear-gradient(180deg, #111827, #0f172a);
        color: #e5eefb;
        border-color: rgba(148, 163, 184, 0.16);
        box-shadow: 0 24px 60px rgba(2, 8, 23, 0.45);
    }

    html.dm .form-control {
        background: rgba(15, 23, 42, 0.9);
        color: #e5eefb;
        border-color: rgba(148, 163, 184, 0.22);
    }

    html.dm .form-control:focus {
        background: rgba(15, 23, 42, 0.98);
        color: #f8fafc;
    }

    html.dm .form-label {
        color: #cbd5e1;
    }

    .print-header {
        text-align: center;
        margin-bottom: 24px;
    }

    .qr-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 18px;
    }

    .qr-print-card {
        border: 1px solid #d1d5db;
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        page-break-inside: avoid;
    }

    .qr-print-card p,
    .qr-preview-card p {
        margin-bottom: 6px;
    }

    @@keyframes buttonFloat {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes titleRise {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .manager-shell {
            padding: 22px 14px;
            border-radius: 20px;
        }

        .action-bar {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .action-bar .btn {
            width: 100%;
            margin-right: 0 !important;
        }

        .history-filters {
            flex-direction: column;
            gap: 8px;
        }
        .history-search, .history-filter {
            width: 100%;
        }
    }

