@code {
    private List<InventoryItem> logs = new();
    private string searchText = "";
    private string modalTitle = "";
    private string submitButtonText = "Save";
    private string newProductName = "";
    private int newQuantity = 1;
    private decimal newPrice;
    private int deleteId = 1;
    private int editId;
    private bool isDeleteMode;
    private bool isEditMode;
    private bool showProductModal;
    private bool showQrModal;
    private bool isLoading = true;
    private string errorMessage = "";
    private string pageError = "";
    private InventoryItem? selectedQrItem;
    private IBrowserFile? selectedImageFile;
    private string? selectedImagePreview;
    private List<ProductLog> historyLogs = new();
    private string historySearch = "";
    private string historyActionFilter = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadDataAsync();
        await LoadHistory();
    }

    private void OnSearchChanged()
    {
        StateHasChanged();
    }

    private IEnumerable<InventoryItem> FilteredLogs
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchText))
                return logs;

            var query = searchText.Trim().ToLower();
            return logs.Where(x => x.Name.ToLower().Contains(query)
                || x.Id.ToString().Contains(query));
        }
    }

    private IEnumerable<(string Name, int Quantity, int MinLevel, int Needed)> RestockSuggestions
    {
        get
        {
            return logs
                .Where(x => x.Quantity < x.MinLevel)
                .Select(x => (Name: x.Name, Quantity: x.Quantity, MinLevel: x.MinLevel, Needed: x.MinLevel - x.Quantity))
                .OrderByDescending(x => x.Needed);
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading = true;
            pageError = "";
            logs = await Repository.GetAllAsync();
        }
        catch (Exception ex)
        {
            pageError = $"Database error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadHistory()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var query = db.ProductLogs.OrderByDescending(x => x.Date).AsQueryable();
            if (!string.IsNullOrWhiteSpace(historySearch))
            {
                var s = historySearch.ToLower();
                query = query.Where(x => x.ProductName.ToLower().Contains(s));
            }
            if (!string.IsNullOrWhiteSpace(historyActionFilter))
            {
                query = query.Where(x => x.Action == historyActionFilter
                    || (historyActionFilter == "Incoming" && x.Action == "KELDI")
                    || (historyActionFilter == "Sold" && x.Action == "SOTILDI")
                    || (historyActionFilter == "Outgoing" && x.Action == "KETDI"));
            }
            historyLogs = await query.Take(50).ToListAsync();
        }
        catch { }
    }

    private Task OpenAddInModal()
    {
        isDeleteMode = false;
        isEditMode = false;
        modalTitle = "Add new product";
        submitButtonText = "Save";
        ResetForm();
        selectedImageFile = null;
        selectedImagePreview = null;
        showProductModal = true;
        return Task.CompletedTask;
    }

    private Task OpenDeleteModal()
    {
        isDeleteMode = true;
        isEditMode = false;
        modalTitle = "Delete product by ID";
        submitButtonText = "Delete";
        ResetForm();
        showProductModal = true;
        return Task.CompletedTask;
    }

    private async Task OpenEditModal(int itemId)
    {
        var item = logs.FirstOrDefault(x => x.Id == itemId) ?? await Repository.GetByIdAsync(itemId);
        if (item is null)
        {
            pageError = "Product to edit was not found.";
            return;
        }

        isDeleteMode = false;
        isEditMode = true;
        editId = item.Id;
        modalTitle = $"Edit product ID {item.Id}";
        submitButtonText = "Update";
        errorMessage = "";
        newProductName = item.Name;
        newQuantity = item.Quantity;
        newPrice = item.Price;
        selectedImageFile = null;
        selectedImagePreview = item.ImageUrl;
        showProductModal = true;
    }

    private Task OpenQrModal(int itemId)
    {
        selectedQrItem = logs.FirstOrDefault(x => x.Id == itemId);
        showQrModal = selectedQrItem is not null;
        return Task.CompletedTask;
    }

    private async Task PrintAllQRCodes()
    {
        if (logs.Count == 0)
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync("printElement", "printableQrArea", "Product QR Codes");
    }

    private void CloseProductModal()
    {
        showProductModal = false;
        errorMessage = "";
    }

    private void CloseQrModal()
    {
        showQrModal = false;
        selectedQrItem = null;
    }

    private void ResetForm()
    {
        newProductName = "";
        newQuantity = 1;
        newPrice = 0;
        deleteId = 1;
        editId = 0;
        errorMessage = "";
    }

    private async Task SubmitModal()
    {
        if (isDeleteMode)
        {
            await DeleteTransaction();
            return;
        }

        if (isEditMode)
        {
            await UpdateTransaction();
            return;
        }

        await AddTransaction();
    }

    private bool IsProductFormInvalid()
    {
        if (string.IsNullOrWhiteSpace(newProductName))
        {
            errorMessage = "Please enter the product name.";
            return true;
        }

        if (newQuantity <= 0)
        {
            errorMessage = "Quantity must be greater than 0.";
            return true;
        }

        if (newPrice <= 0)
        {
            errorMessage = "Price must be greater than 0.";
            return true;
        }

        errorMessage = "";
        return false;
    }

    private async Task AddTransaction()
    {
        if (IsProductFormInvalid())
        {
            return;
        }

        try
        {
            var existing = logs.FirstOrDefault(p => p.Name.Equals(newProductName, StringComparison.OrdinalIgnoreCase));
            if (existing is not null)
            {
                var prevQty = existing.Quantity;
                existing.Quantity += newQuantity;
                existing.TotalAmount = existing.Quantity * existing.Price;
                if (selectedImageFile is not null)
                {
                    var url = await SaveImageAsync(newProductName);
                    if (url is not null) existing.ImageUrl = url;
                }
                await Repository.UpdateAsync(existing);
                await using (var db = await DbFactory.CreateDbContextAsync())
                {
                    db.ProductLogs.Add(new ProductLog
                    {
                        ProductName = newProductName,
                        ProductId = existing.Id,
                        Action = "Incoming",
                        PreviousQty = prevQty,
                        ChangeQty = newQuantity,
                        NewQty = existing.Quantity
                    });
                    await db.SaveChangesAsync();
                }
                errorMessage = $"Updated: '{newProductName}' {prevQty} +{newQuantity} → {existing.Quantity}";
            }
            else
            {
                var saved = await Repository.AddAsync(new InventoryItem
                {
                    Name = newProductName,
                    Quantity = newQuantity,
                    Price = newPrice,
                    MinLevel = 5
                });
                if (selectedImageFile is not null)
                {
                    var url = await SaveImageAsync(saved.Name);
                    if (url is not null)
                    {
                        saved.ImageUrl = url;
                        await Repository.UpdateAsync(saved);
                    }
                }
                errorMessage = "";
            }

            await LoadDataAsync();
            CloseProductModal();
            ResetForm();
        }
        catch (Exception ex)
        {
            errorMessage = $"Add failed: {ex.Message}";
        }
    }

    private async Task UpdateTransaction()
    {
        if (IsProductFormInvalid())
        {
            return;
        }

        try
        {
            var oldProduct = logs.FirstOrDefault(x => x.Id == editId);
            if (oldProduct is null)
            {
                errorMessage = "Product to edit was not found.";
                return;
            }

            var prevQty = oldProduct.Quantity;
            var diff = newQuantity - prevQty;
            var action = diff > 0 ? "Incoming" : diff < 0 ? "Outgoing" : "Change";

            var imageUrl = oldProduct.ImageUrl;
            if (selectedImageFile is not null)
            {
                var url = await SaveImageAsync(newProductName);
                if (url is not null) imageUrl = url;
            }

            var updated = await Repository.UpdateAsync(new InventoryItem
            {
                Id = editId,
                Name = newProductName,
                Quantity = newQuantity,
                Price = newPrice,
                MinLevel = oldProduct.MinLevel,
                ImageUrl = imageUrl ?? ""
            });

            if (diff != 0)
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                db.ProductLogs.Add(new ProductLog
                {
                    ProductName = newProductName,
                    ProductId = editId,
                    Action = action,
                    PreviousQty = prevQty,
                    ChangeQty = Math.Abs(diff),
                    NewQty = newQuantity
                });
                await db.SaveChangesAsync();
            }

            await LoadDataAsync();
            CloseProductModal();
            ResetForm();
        }
        catch (Exception ex)
        {
            errorMessage = $"Update failed: {ex.Message}";
        }
    }

    private async Task DeleteTransaction()
    {
        try
        {
            var deleted = await Repository.DeleteAsync(deleteId);
            if (!deleted)
            {
                errorMessage = "No product found with this ID.";
                return;
            }

            await LoadDataAsync();
            CloseProductModal();
            ResetForm();
        }
        catch (Exception ex)
        {
            errorMessage = $"Delete failed: {ex.Message}";
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedImageFile = e.File;
        selectedImagePreview = null;
    }

    private static readonly HashSet<string> AllowedExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".png", ".jpg", ".jpeg", ".gif", ".bmp", ".webp", ".svg"
    };

    private async Task<string?> SaveImageAsync(string productName)
    {
        if (selectedImageFile is null) return null;

        var ext = Path.GetExtension(selectedImageFile.Name);
        if (!AllowedExtensions.Contains(ext))
        {
            errorMessage = "Only image files are allowed (PNG, JPG, JPEG, GIF, BMP, WEBP, SVG).";
            return null;
        }

        var fileName = SanitizeFileName(productName) + ext;
        var dir = Path.Combine(WebHostEnvironment.WebRootPath, "images", "products");
        Directory.CreateDirectory(dir);
        var filePath = Path.Combine(dir, fileName);

        await using var stream = File.Create(filePath);
        await selectedImageFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(stream);

        var url = $"/images/products/{fileName}";
        selectedImagePreview = url;
        return url;
    }

    private static string SanitizeFileName(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var sanitized = new string(name.Where(c => !invalid.Contains(c)).ToArray()).Trim();
        return string.IsNullOrWhiteSpace(sanitized) ? "product" : sanitized;
    }

    private static string GetQrCodeUrl(InventoryItem item)
    {
        var payload =
            $"ID:{item.Id};Product:{item.Name};Quantity:{item.Quantity};Price:{item.Price:N0};Total:{item.TotalAmount:N0}";

        return $"https://api.qrserver.com/v1/create-qr-code/?size=220x220&data={Uri.EscapeDataString(payload)}";
    }

    private static string GetActionLabel(string action) => action switch
    {
        "KELDI" or "Incoming" => "Incoming",
        "SOTILDI" or "Sold" => "Sold",
        "KETDI" or "Outgoing" => "Outgoing",
        "O'ZGARISH" or "Change" => "Change",
        _ => action
    };

    private static string GetActionClass(string action) => action switch
    {
        "KELDI" or "Incoming" => "incoming",
        "SOTILDI" or "Sold" => "sold",
        "KETDI" or "Outgoing" => "outgoing",
        "O'ZGARISH" or "Change" => "change",
        _ => action.ToLower()
    };

    private static bool IsOutgoingAction(string action) => action switch
    {
        "SOTILDI" or "Sold" or "KETDI" or "Outgoing" => true,
        _ => false
    };

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    [Inject]
    private IInventoryRepository Repository { get; set; } = null!;
}