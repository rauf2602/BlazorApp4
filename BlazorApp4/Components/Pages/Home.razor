        .manager-icon { font-size: 1.2rem !important; }
        .search-row { max-width: 100% !important; }
        .search-row .form-control { font-size: .8rem !important; padding: 6px 10px !important; }
        .summary-bar { flex-direction: column !important; gap: 6px !important; }
        .summary-item { width: 100% !important; justify-content: space-between !important; padding: 6px !important; }
        .summary-label { font-size: .75rem !important; }
        .summary-value { font-size: .9rem !important; }
