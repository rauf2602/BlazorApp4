@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using BlazorApp4.Models
@using BlazorApp4.Services
@using BlazorApp4.Data
@using Microsoft.EntityFrameworkCore
@inject CustomAuthProvider AuthState
@inject NavigationManager Nav
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IWebHostEnvironment WebHostEnvironment

<h2 class="text-center mt-4">Store Manager</h2>

<div class="container mt-5 manager-shell">
    @if (RestockSuggestions.Any())
    {
        <div class="restock-alert">
            <h5>⚠️ Restock Suggestions</h5>
            @foreach (var suggestion in RestockSuggestions)
            {
                <div class="restock-item">
                    <span class="restock-text">👉 Need to restock <b>@suggestion.Name</b> — <b>@suggestion.Needed</b> more needed</span>
                    <span class="restock-badge">Current: @suggestion.Quantity / Min: @suggestion.MinLevel</span>
                </div>
            }
        </div>
    }

    <div class="search-row mb-4">
        <input type="text" class="form-control search-box" @bind="searchText" @bind:after="OnSearchChanged" placeholder="🔍 Search by product name or ID..." />
    </div>

    <div class="text-center mb-4 action-bar">
        <button class="btn btn-success me-3 animated-btn glow-green" @onclick="OpenAddInModal">
            Add Item
        </button>

        <button class="btn btn-danger me-3 animated-btn glow-red" @onclick="OpenDeleteModal">
            Delete Item
        </button>

        <button class="btn btn-dark animated-btn glow-slate" @onclick="PrintAllQRCodes" disabled="@(logs.Count == 0)">
            Print QR
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger mb-4">@pageError</div>
    }

    <table class="table text-center align-middle inventory-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Product</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Total</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (isLoading)
            {
                <tr>
                    <td colspan="8">Loading...</td>
                </tr>
            }
            else if (!FilteredLogs.Any())
            {
                <tr>
                    <td colspan="8">No results found</td>
                </tr>
            }
            else
            {
                @foreach (var item in FilteredLogs)
                {
                    var isLow = item.Quantity < item.MinLevel;
                    <tr class="@(isLow ? "low-stock-row" : "")">
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td class="@(isLow ? "low-stock" : "")">@item.Quantity</td>
                        <td>@item.Price.ToString("N0") TJS</td>
                        <td>@item.TotalAmount.ToString("N0") TJS</td>
                        <td>
                            @if (isLow)
                            {
                                <span class="badge bg-warning text-dark">⚠️ Low</span>
                            }
                            else
                            {
                                <span class="badge bg-success">OK</span>
                            }
                        </td>
                        <td>@item.Date.ToString("dd.MM HH:mm")</td>
                        <td>
                            <div class="action-buttons">
                                <button class="btn btn-info btn-sm text-white animated-btn glow-cyan" @onclick="() => OpenQrModal(item.Id)">
                                    QR
                                </button>
                                <button class="btn btn-warning btn-sm animated-btn glow-amber" @onclick="() => OpenEditModal(item.Id)">
                                    Edit
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (showProductModal)
{
    <div class="modal fade show d-block modal-overlay" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@modalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseProductModal"></button>
                </div>
                <div class="modal-body">
                    @if (isDeleteMode)
                    {
                        <div class="mb-3">
                            <label class="form-label">ID to delete</label>
                            <input type="number" class="form-control" @bind="deleteId" min="1" />
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">Product name</label>
                            <input type="text" class="form-control" @bind="newProductName" placeholder="Example: Apple" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quantity</label>
                            <input type="number" class="form-control" @bind="newQuantity" min="1" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Price (TJS)</label>
                            <input type="number" class="form-control" @bind="newPrice" min="0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Product Image</label>
                            <InputFile OnChange="HandleFileSelected" accept="image/*" />
                            @if (!string.IsNullOrEmpty(selectedImagePreview))
                            {
                                <div class="mt-2">
                                    <img src="@selectedImagePreview" alt="Preview" style="max-width:100px;max-height:100px;object-fit:contain;border-radius:8px;border:1px solid #ddd;" />
                                </div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseProductModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SubmitModal">
                        @submitButtonText
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showQrModal && selectedQrItem is not null)
{
    <div class="modal fade show d-block modal-overlay" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Product QR Code</h5>
                    <button type="button" class="btn-close" @onclick="CloseQrModal"></button>
                </div>
                <div class="modal-body text-center">
                    <div class="qr-preview-card">
                        <img src="@GetQrCodeUrl(selectedQrItem)" alt="QR Code" class="img-fluid qr-image mb-3" />
                        <h5 class="mb-2">@selectedQrItem.Name</h5>
                        <p class="mb-1">ID: @selectedQrItem.Id</p>
                        <p class="mb-1">Quantity: @selectedQrItem.Quantity</p>
                        <p class="mb-0">Price: @selectedQrItem.Price.ToString("N0") TJS</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseQrModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<div id="printableQrArea" class="print-area">
    <div class="print-header">
        <h3>Product QR Codes</h3>
        <p>Date: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</p>
    </div>
    <div class="qr-grid">
        @foreach (var item in logs)
        {
            <div class="qr-print-card">
                <img src="@GetQrCodeUrl(item)" alt="QR Code" class="qr-image" />
                <h5>@item.Name</h5>
                <p>ID: @item.Id</p>
                <p>Quantity: @item.Quantity</p>
                <p>Price: @item.Price.ToString("N0") TJS</p>
            </div>
        }
    </div>
</div>

<!-- Product History Panel -->
<div class="container mt-4 history-shell">
    <div class="history-header">
        <h3>📦 Product History</h3>
        <div class="history-filters">
            <input type="text" class="history-search" @bind="historySearch" @bind:after="LoadHistory" placeholder="🔍 Product name..." />
            <select class="history-filter" @bind="historyActionFilter" @bind:after="LoadHistory">
                <option value="">All</option>
                <option value="Incoming">📥 Incoming</option>
                <option value="Sold">📤 Sold</option>
                <option value="Outgoing">🚚 Outgoing</option>
                <option value="Change">🔄 Change</option>
            </select>
        </div>
    </div>

    <div class="history-table-wrapper">
        <table class="history-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Product</th>
                    <th>Action</th>
                    <th>Previous</th>
                    <th>Change</th>
                    <th>New</th>
                </tr>
            </thead>
            <tbody>
                @if (!historyLogs.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No history found</td>
                    </tr>
                }
                else
                {
                    @foreach (var log in historyLogs)
                    {
                        <tr>
                            <td>@log.Date.ToString("dd.MM HH:mm")</td>
                            <td><strong>@log.ProductName</strong></td>
                            <td>
                                <span class="action-badge action-@GetActionClass(log.Action)">
                                    @GetActionLabel(log.Action)
                                </span>
                            </td>
                            <td>@log.PreviousQty</td>
                            <td class="@(IsOutgoingAction(log.Action) ? "text-danger" : "text-success")">
                                @(IsOutgoingAction(log.Action) ? "-" : "+")@log.ChangeQty
                            </td>
                            <td><strong>@log.NewQty</strong></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    h2 {
        font-weight: bold;
        color: #1e293b;
        letter-spacing: 0.04em;
        animation: titleRise 0.8s ease;
        transition: color 0.25s ease;
    }

    .search-row {
        max-width: 480px;
        margin: 0 auto;
    }

    .search-box {
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 999px;
        padding: 12px 24px;
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

    .search-box:focus {
        background: #ffffff;
        border-color: #38bdf8;
        box-shadow: 0 0 0 0.18rem rgba(56, 189, 248, 0.15);
    }

    .restock-alert {
        background: linear-gradient(135deg, #fff3cd, #ffeaa7);
        border: 1px solid #f59e0b;
