@code {
    private List<InventoryItem> allProducts = new();
    private List<InventoryItem> filteredProducts = new();
    private List<CartItem> cart = new();
    private List<Sale> recentSales = new();
    private string searchText = "";
    private string? errorMessage;
    private string? successMessage;
    private bool isLoadingProducts = true;
    private bool isProcessing = false;
    private int? pulseProductId;

    private void AddToCart(InventoryItem product)
    {
        if (product.Quantity <= 0) return;

        errorMessage = null;
        successMessage = null;

        var existing = cart.FirstOrDefault(c => c.ProductId == product.Id);
        if (existing is not null)
        {
            if (existing.Quantity >= product.Quantity)
            {
                errorMessage = $"Not enough stock for {product.Name}. Available: {product.Quantity}";
                StateHasChanged();
                return;
            }
            existing.Quantity++;
            pulseProductId = product.Id;
            _ = Task.Delay(400).ContinueWith(_ => { pulseProductId = null; InvokeAsync(StateHasChanged); });
        }
        else
        {
            cart.Add(new CartItem
            {
                ProductId = product.Id,
                ProductName = product.Name,
                UnitPrice = product.Price,
                Quantity = 1
            });
        }
        StateHasChanged();
    }

    private void ChangeQty(int index, int delta)
    {
        var item = cart[index];
        var product = allProducts.FirstOrDefault(p => p.Id == item.ProductId);
        var newQty = item.Quantity + delta;

        if (product is not null && newQty > product.Quantity)
        {
            errorMessage = $"Not enough stock for {item.ProductName}. Available: {product.Quantity}";
            StateHasChanged();
            return;
        }

        if (newQty > 0)
        {
            item.Quantity = newQty;
            errorMessage = null;
        }
        StateHasChanged();
    }

    private void ValidateQty(int index)
    {
        var item = cart[index];
        var product = allProducts.FirstOrDefault(p => p.Id == item.ProductId);

        if (item.Quantity <= 0)
        {
            cart.RemoveAt(index);
        }
        else if (product is not null && item.Quantity > product.Quantity)
        {
            item.Quantity = product.Quantity;
            errorMessage = $"Reduced to available stock: {product.Quantity}";
        }
        StateHasChanged();
    }

    private void RemoveFromCart(int index)
    {
        cart.RemoveAt(index);
        errorMessage = null;
        StateHasChanged();
    }

    private void ClearCart()
    {
        cart = new List<CartItem>();
        errorMessage = null;
        successMessage = null;
        StateHasChanged();
    }

    private decimal CartTotal => cart.Sum(c => c.LineTotal);

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadProducts();
        await LoadRecentSales();
    }

    private async Task LoadProducts()
    {
        isLoadingProducts = true;
        try
        {
            allProducts = await InventoryRepository.GetAllAsync();
            filteredProducts = allProducts;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load products: {ex.Message}";
        }
        finally
        {
            isLoadingProducts = false;
        }
    }

    private async Task LoadRecentSales()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            recentSales = await db.Sales
                .OrderByDescending(s => s.SaleDate)
                .Take(10)
                .ToListAsync();
        }
        catch { }
    }

    private void FilterProducts()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredProducts = allProducts;
        }
        else
        {
            var query = searchText.Trim().ToLower();
            filteredProducts = allProducts.Where(p =>
                p.Name.ToLower().Contains(query) || p.Id.ToString().Contains(query)
            ).ToList();
        }
    }

    private async Task ProcessSale()
    {
        if (!cart.Any() || isProcessing) return;

        isProcessing = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var freshProducts = await InventoryRepository.GetAllAsync();

            foreach (var item in cart)
            {
                var product = freshProducts.FirstOrDefault(p => p.Id == item.ProductId);
                if (product is null || product.Quantity < item.Quantity)
                {
                    errorMessage = $"Not enough stock for {item.ProductName}. Available: {product?.Quantity ?? 0}";
                    isProcessing = false;
                    StateHasChanged();
                    return;
                }
            }

            var sale = new Sale
            {
                SaleDate = DateTime.Now,
                TotalPrice = CartTotal
            };

            db.Sales.Add(sale);
            await db.SaveChangesAsync();

            foreach (var item in cart)
            {
                db.SaleItems.Add(new SaleItem
                {
                    SaleId = sale.Id,
                    ProductId = item.ProductId,
                    ProductName = item.ProductName,
                    Quantity = item.Quantity,
                    UnitPrice = item.UnitPrice
                });
            }

            foreach (var item in cart)
            {
                var product = freshProducts.First(p => p.Id == item.ProductId);
                var prevQty = product.Quantity;
                product.Quantity -= item.Quantity;
                product.TotalAmount = product.Quantity * product.Price;
                db.InventoryItems.Update(product);

                db.ProductLogs.Add(new ProductLog
                {
                    ProductName = item.ProductName,
                    ProductId = item.ProductId,
                    Action = "Sold",
                    PreviousQty = prevQty,
                    ChangeQty = item.Quantity,
                    NewQty = product.Quantity
                });
            }

            await db.SaveChangesAsync();

            successMessage = $"Sale completed! Total: {CartTotal:N0} TJS";
            cart = new List<CartItem>();
            await LoadProducts();
            await LoadRecentSales();
        }
        catch (Exception ex)
        {
            errorMessage = $"Sale failed: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private string GetProductImage(string name)
    {
        var n = name.ToLower().Trim();
        if (n.Contains("apple") || n.Contains("olma")) return "/images/products/apple.png";
        if (n.Contains("banana") || n.Contains("banan")) return "/images/products/banana.png";
        if (n.Contains("cola") || n.Contains("coca") || n.Contains("coke") || n.Contains("koka") || n.Contains("colla")) return "/images/products/colla.png";
        if (n.Contains("fanta")) return "/images/products/fanta.png";
        if (n.Contains("hleb") || n.Contains("bread")) return "/images/products/hleb.png";
        if (n.Contains("non")) return "/images/products/non.png";
        if (n.Contains("Rc")) return "/images/products/rc.png";
        if (n.Contains("pepsi")) return "/images/products/pepsi.png";
        if (n.Contains("pizza")) return "/images/products/pizza.png";
        if (n.Contains("alpen gold")) return "/images/products/alpen gold.png";
        return "";
    }
}
