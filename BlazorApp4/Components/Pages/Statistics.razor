@code {
    private bool isLoading = true;
    private DateTime selectedMonth = DateTime.Now;

    private int totalIncoming;
    private int totalSold;
    private int totalOutgoing;
    private int incomingCount;
    private int soldCount;
    private int outgoingCount;
    private int currentStock;

    private List<ProductStat> productStats = new();
    private List<ProductLog> recentLogs = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadStats();
    }

    private static int GetPercentage(int value, int total)
    {
        if (total == 0) return 0;
        return (int)Math.Round((double)value / total * 100);
    }

    private static string GetActionLabel(string action) => action switch
    {
        "KELDI" or "Incoming" => "Incoming",
        "SOTILDI" or "Sold" => "Sold",
        "KETDI" or "Outgoing" => "Outgoing",
        "O'ZGARISH" or "Change" => "Change",
        _ => action
    };

    private static string GetActionClass(string action) => action switch
    {
        "KELDI" or "Incoming" => "incoming",
        "SOTILDI" or "Sold" => "sold",
        "KETDI" or "Outgoing" => "outgoing",
        "O'ZGARISH" or "Change" => "change",
        _ => action.ToLower()
    };

    private static string GetProductImage(string name)
    {
        var n = name.ToLower().Trim();
        if (n.Contains("apple") || n.Contains("olma")) return "/images/products/apple.png";
        if (n.Contains("banana") || n.Contains("banan")) return "/images/products/banana.png";
        if (n.Contains("cola") || n.Contains("coca") || n.Contains("coke") || n.Contains("koka") || n.Contains("colla")) return "/images/products/colla.png";
        if (n.Contains("fanta")) return "/images/products/fanta.png";
        if (n.Contains("hleb") || n.Contains("bread")) return "/images/products/hleb.png";
        if (n.Contains("non") || n.Contains("bread")) return "/images/products/non.png";
        return "";
    }

    private async Task LoadStats()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var start = new DateTime(selectedMonth.Year, selectedMonth.Month, 1);
            var end = start.AddMonths(1);

            var logs = await db.ProductLogs
                .Where(x => x.Date >= start && x.Date < end)
                .OrderByDescending(x => x.Date)
                .ToListAsync();

            totalIncoming = logs.Where(x => x.Action == "Incoming" || x.Action == "KELDI").Sum(x => x.ChangeQty);
            incomingCount = logs.Count(x => x.Action == "Incoming" || x.Action == "KELDI");

            totalSold = logs.Where(x => x.Action == "Sold" || x.Action == "SOTILDI").Sum(x => x.ChangeQty);
            soldCount = logs.Count(x => x.Action == "Sold" || x.Action == "SOTILDI");

            totalOutgoing = logs.Where(x => x.Action == "Outgoing" || x.Action == "KETDI").Sum(x => x.ChangeQty);
            outgoingCount = logs.Count(x => x.Action == "Outgoing" || x.Action == "KETDI");

            currentStock = await db.InventoryItems.SumAsync(x => x.Quantity);

            var items = await db.InventoryItems.ToListAsync();

            productStats = logs
                .GroupBy(x => x.ProductId)
                .Select(g => new ProductStat
                {
                    ProductId = g.Key,
                    ProductName = g.First().ProductName,
                    ImageUrl = items.FirstOrDefault(i => i.Id == g.Key)?.ImageUrl ?? "",
                    Incoming = g.Where(x => x.Action == "Incoming" || x.Action == "KELDI").Sum(x => x.ChangeQty),
                    Sold = g.Where(x => x.Action == "Sold" || x.Action == "SOTILDI").Sum(x => x.ChangeQty),
                    Outgoing = g.Where(x => x.Action == "Outgoing" || x.Action == "KETDI").Sum(x => x.ChangeQty),
                    CurrentQty = items.FirstOrDefault(i => i.Id == g.Key)?.Quantity ?? 0
                })
                .OrderByDescending(x => x.Incoming + x.Sold + x.Outgoing)
                .ToList();

            recentLogs = logs.Take(20).ToList();
        }
        catch { }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private class ProductStat
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public int Incoming { get; set; }
        public int Sold { get; set; }
        public int Outgoing { get; set; }
        public int CurrentQty { get; set; }
    }
}
