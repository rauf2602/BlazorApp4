@page "/statistics"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using BlazorApp4.Models
@using BlazorApp4.Data
@using Microsoft.EntityFrameworkCore
@inject CustomAuthProvider AuthState
@inject NavigationManager Nav
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="stats-page">
    <div class="stats-header">
        <div class="header-left">
            <h1 class="stats-title">
                <span class="title-glow">📊</span>
                <span>Statistics</span>
            </h1>
            <p class="header-subtitle">@selectedMonth.ToString("MMMM yyyy") — Monthly Report</p>
        </div>
        <div class="month-selector">
            <label class="month-label">📅 Month:</label>
            <input type="month" class="month-input" @bind="selectedMonth" @bind:after="LoadStats" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="loading-card skeleton-card">
                <div class="skeleton-circle"></div>
                <div class="skeleton-lines">
                    <div class="skeleton-line w-40"></div>
                    <div class="skeleton-line w-60"></div>
                </div>
            </div>
            <div class="loading-card skeleton-card">
                <div class="skeleton-circle"></div>
                <div class="skeleton-lines">
                    <div class="skeleton-line w-50"></div>
                    <div class="skeleton-line w-30"></div>
                </div>
            </div>
            <div class="loading-card skeleton-card">
                <div class="skeleton-circle"></div>
                <div class="skeleton-lines">
                    <div class="skeleton-line w-45"></div>
                    <div class="skeleton-line w-55"></div>
                </div>
            </div>
            <div class="loading-card skeleton-card">
                <div class="skeleton-circle"></div>
                <div class="skeleton-lines">
                    <div class="skeleton-line w-35"></div>
                    <div class="skeleton-line w-65"></div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card card-green">
                <div class="card-glow green-glow"></div>
                <div class="card-accent"></div>
                <div class="card-icon-wrap">
                    <div class="icon-circle icon-green">📥</div>
                </div>
                <div class="card-content">
                    <span class="card-label">Incoming</span>
                    <span class="card-value animate-number">@totalIncoming</span>
                    <span class="card-sub">@incomingCount transactions</span>
                </div>
                <div class="card-bar">
                    <div class="bar-fill bar-green" style="width: @GetPercentage(totalIncoming, totalIncoming + totalSold + totalOutgoing)%"></div>
                </div>
            </div>

            <div class="summary-card card-red">
                <div class="card-glow red-glow"></div>
                <div class="card-accent"></div>
                <div class="card-icon-wrap">
                    <div class="icon-circle icon-red">📤</div>
                </div>
                <div class="card-content">
                    <span class="card-label">Sold</span>
                    <span class="card-value animate-number">@totalSold</span>
                    <span class="card-sub">@soldCount transactions</span>
                </div>
                <div class="card-bar">
                    <div class="bar-fill bar-red" style="width: @GetPercentage(totalSold, totalIncoming + totalSold + totalOutgoing)%"></div>
                </div>
            </div>

            <div class="summary-card card-orange">
                <div class="card-glow orange-glow"></div>
                <div class="card-accent"></div>
                <div class="card-icon-wrap">
                    <div class="icon-circle icon-orange">🚚</div>
                </div>
                <div class="card-content">
                    <span class="card-label">Outgoing</span>
                    <span class="card-value animate-number">@totalOutgoing</span>
                    <span class="card-sub">@outgoingCount transactions</span>
                </div>
                <div class="card-bar">
                    <div class="bar-fill bar-orange" style="width: @GetPercentage(totalOutgoing, totalIncoming + totalSold + totalOutgoing)%"></div>
                </div>
            </div>

            <div class="summary-card card-blue">
                <div class="card-glow blue-glow"></div>
                <div class="card-accent"></div>
                <div class="card-icon-wrap">
                    <div class="icon-circle icon-blue">📦</div>
                </div>
                <div class="card-content">
                    <span class="card-label">Total Products</span>
                    <span class="card-value animate-number">@currentStock</span>
                    <span class="card-sub">Current in stock</span>
                </div>
            </div>
        </div>

        <!-- Visual Bar Chart -->
        @if (totalIncoming + totalSold + totalOutgoing > 0)
        {
            <div class="chart-section">
                <h3 class="section-title">
                    <span class="title-line"></span>
                    Transaction Breakdown
                </h3>
                <div class="bar-chart">
                    <div class="chart-row">
                        <div class="chart-label">
                            <span class="chart-dot dot-green"></span>
                            Incoming
                        </div>
                        <div class="chart-bar-bg">
                            <div class="chart-bar-fill chart-bar-green" style="width: @GetPercentage(totalIncoming, totalIncoming + totalSold + totalOutgoing)%"></div>
                        </div>
                        <div class="chart-value">@totalIncoming</div>
                    </div>
                    <div class="chart-row">
                        <div class="chart-label">
                            <span class="chart-dot dot-red"></span>
                            Sold
                        </div>
                        <div class="chart-bar-bg">
                            <div class="chart-bar-fill chart-bar-red" style="width: @GetPercentage(totalSold, totalIncoming + totalSold + totalOutgoing)%"></div>
                        </div>
                        <div class="chart-value">@totalSold</div>
                    </div>
                    <div class="chart-row">
                        <div class="chart-label">
                            <span class="chart-dot dot-orange"></span>
                            Outgoing
                        </div>
                        <div class="chart-bar-bg">
                            <div class="chart-bar-fill chart-bar-orange" style="width: @GetPercentage(totalOutgoing, totalIncoming + totalSold + totalOutgoing)%"></div>
                        </div>
                        <div class="chart-value">@totalOutgoing</div>
                    </div>
                </div>
            </div>
        }

        <!-- Product Breakdown Table -->
        <div class="product-stats">
            <h3 class="section-title">
                <span class="title-line"></span>
                By Product
            </h3>
            <div class="table-wrapper">
                <table class="stats-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Product</th>
                            <th>
                                <span class="th-badge th-green">📥 Incoming</span>
                            </th>
                            <th>
                                <span class="th-badge th-red">📤 Sold</span>
                            </th>
                            <th>
                                <span class="th-badge th-orange">🚚 Outgoing</span>
                            </th>
                            <th>In Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!productStats.Any())
                        {
                            <tr>
                                <td colspan="6" class="empty-row">
                                    <div class="empty-icon">📭</div>
                                    <span>No activity this month</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @for (int i = 0; i < productStats.Count; i++)
                            {
                                var stat = productStats[i];
                                var total = stat.Incoming + stat.Sold + stat.Outgoing;
                                <tr>
                                    <td class="row-num">@(i + 1)</td>
                                    <td class="product-name-cell">
                                        <div class="product-avatar-wrap">
                                            @if (!string.IsNullOrEmpty(GetProductImage(stat.ProductName)))
                                            {
                                                <img src="@GetProductImage(stat.ProductName)" alt="" class="mini-thumb" />
                                            }
                                            else
                                            {
                                                <div class="mini-avatar">@(stat.ProductName.Substring(0, Math.Min(2, stat.ProductName.Length)).ToUpper())</div>
                                            }
                                        </div>
                                        <span class="name-text">@stat.ProductName</span>
                                    </td>
                                    <td>
                                        <div class="cell-with-bar">
                                            <span class="cell-value val-green">@stat.Incoming</span>
                                            <div class="cell-bar"><div class="cell-bar-fill cell-bar-green" style="width: @GetPercentage(stat.Incoming, total)%"></div></div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="cell-with-bar">
                                            <span class="cell-value val-red">@stat.Sold</span>
                                            <div class="cell-bar"><div class="cell-bar-fill cell-bar-red" style="width: @GetPercentage(stat.Sold, total)%"></div></div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="cell-with-bar">
                                            <span class="cell-value val-orange">@stat.Outgoing</span>
                                            <div class="cell-bar"><div class="cell-bar-fill cell-bar-orange" style="width: @GetPercentage(stat.Outgoing, total)%"></div></div>
                                        </div>
                                    </td>
                                    <td class="stock-cell">
                                        <span class="stock-badge @(stat.CurrentQty <= 5 ? "stock-low" : "stock-ok")">
                                            @(stat.CurrentQty <= 0 ? "⛔ " : stat.CurrentQty <= 5 ? "⚠️ " : "✅ ")@stat.CurrentQty
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Activity Log -->
        <div class="recent-activity">
            <h3 class="section-title">
                <span class="title-line"></span>
                Recent Activity
            </h3>
            <div class="activity-timeline">
                @if (!recentLogs.Any())
                {
                    <div class="empty-activity">
                        <div class="empty-icon">📭</div>
                        No activity found
                    </div>
                }
                else
                {
                    @for (int i = 0; i < recentLogs.Count; i++)
                    {
                        var log = recentLogs[i];
                        <div class="timeline-item action-@GetActionClass(log.Action)">
                            <div class="timeline-connector">
                                @if (i < recentLogs.Count - 1)
                                {
                                    <div class="timeline-line"></div>
                                }
                            </div>
                            <div class="timeline-dot-wrap">
                                <div class="timeline-dot"></div>
                            </div>
                            <div class="timeline-card">
                                <div class="timeline-header">
                                    <span class="timeline-product">@log.ProductName</span>
                                    <span class="timeline-time">@log.Date.ToString("dd.MM HH:mm")</span>
                                </div>
                                <div class="timeline-body">
                                    <span class="action-badge action-@GetActionClass(log.Action)">
                                        @GetActionLabel(log.Action)
                                    </span>
                                    <span class="timeline-qty">@log.ChangeQty units</span>
                                    <span class="timeline-change">@log.PreviousQty → @log.NewQty</span>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<style>
    :root {
        --primary: #6366f1;
        --primary-dark: #4f46e5;
        --primary-glow: rgba(99,102,241,.25);
        --success: #10b981;
        --success-dark: #059669;
        --success-bg: #ecfdf5;
        --success-glow: rgba(16,185,129,.2);
        --danger: #ef4444;
        --danger-dark: #dc2626;
        --danger-bg: #fef2f2;
        --danger-glow: rgba(239,68,68,.2);
        --warning: #f59e0b;
        --warning-dark: #d97706;
        --warning-bg: #fffbeb;
        --warning-glow: rgba(245,158,11,.2);
        --info: #3b82f6;
        --info-bg: #eff6ff;
        --info-glow: rgba(59,130,246,.2);
        --bg: #f1f5f9;
        --surface: #ffffff;
        --surface-hover: #f8fafc;
        --text: #0f172a;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --border: #e2e8f0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
        --shadow: 0 4px 12px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.04);
        --shadow-lg: 0 12px 32px rgba(0,0,0,.08), 0 4px 8px rgba(0,0,0,.04);
        --shadow-xl: 0 20px 48px rgba(0,0,0,.1);
        --radius: 14px;
        --radius-lg: 20px;
    }

    html.dm {
        --bg: #0b1120;
        --surface: #131c31;
        --surface-hover: #1a2744;
        --text: #f1f5f9;
        --text-secondary: #94a3b8;
        --text-muted: #64748b;
        --border: #1e293b;
        --success-bg: rgba(16,185,129,.12);
        --danger-bg: rgba(239,68,68,.12);
        --warning-bg: rgba(245,158,11,.12);
        --info-bg: rgba(59,130,246,.12);
        --shadow-sm: 0 1px 3px rgba(0,0,0,.2);
        --shadow: 0 4px 12px rgba(0,0,0,.25);
        --shadow-lg: 0 12px 32px rgba(0,0,0,.3);
    }

    .stats-page {
        min-height: 100vh;
        background: var(--bg);
        padding: 28px 24px;
    }

    /* ===== HEADER ===== */
    .stats-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .header-left {
        animation: fadeSlideUp .5s ease;
    }

    .stats-title {
        display: flex;
        align-items: center;
        gap: 14px;
        color: var(--text);
        font-size: 2rem;
        font-weight: 900;
        margin: 0;
        letter-spacing: -.02em;
    }

    .title-glow {
        filter: drop-shadow(0 2px 8px var(--primary-glow));
        animation: iconBounce 2s ease infinite;
    }

    .header-subtitle {
        margin: 6px 0 0;
        font-size: .95rem;
        color: var(--text-muted);
        font-weight: 500;
        text-transform: capitalize;
    }

    .month-selector {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--surface);
        padding: 8px 16px;
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
    }

    .month-label {
        font-size: .9rem;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .month-input {
        padding: 6px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface-hover);
        color: var(--text);
        font-size: .9rem;
        font-weight: 600;
        transition: all .2s;
    }

    .month-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-glow);
        background: var(--surface);
    }

    /* ===== LOADING SKELETON ===== */
    .loading-state {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
    }

    .skeleton-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 24px;
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
    }

    .skeleton-circle {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: linear-gradient(90deg, var(--surface-hover) 25%, var(--border) 50%, var(--surface-hover) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        flex-shrink: 0;
    }

    .skeleton-lines { display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .skeleton-line { height: 14px; border-radius: 7px; background: linear-gradient(90deg, var(--surface-hover) 25%, var(--border) 50%, var(--surface-hover) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; }
    .w-30 { width: 30%; }
    .w-40 { width: 40%; }
    .w-50 { width: 50%; }
    .w-55 { width: 55%; }
    .w-60 { width: 60%; }
    .w-65 { width: 65%; }

   

    /* ===== SUMMARY CARDS ===== */
    .summary-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
    }

    .summary-card {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        padding: 24px;
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        transition: all .3s ease;
        animation: fadeSlideUp .5s ease both;
    }

    .summary-card:nth-child(1) { animation-delay: .1s; }
    .summary-card:nth-child(2) { animation-delay: .15s; }
    .summary-card:nth-child(3) { animation-delay: .2s; }
    .summary-card:nth-child(4) { animation-delay: .25s; }

    .summary-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .card-glow {
        position: absolute;
        top: -30px;
        right: -30px;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        opacity: .12;
        filter: blur(20px);
    }

    .green-glow { background: var(--success); }
    .red-glow { background: var(--danger); }
    .orange-glow { background: var(--warning); }
    .blue-glow { background: var(--info); }

    .card-accent {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
    }

    .card-green .card-accent { background: linear-gradient(90deg, var(--success), var(--success-dark)); }
    .card-red .card-accent { background: linear-gradient(90deg, var(--danger), var(--danger-dark)); }
    .card-orange .card-accent { background: linear-gradient(90deg, var(--warning), var(--warning-dark)); }
    .card-blue .card-accent { background: linear-gradient(90deg, var(--info), #2563eb); }

    .card-icon-wrap {
        margin-bottom: 16px;
    }

    .icon-circle {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: var(--shadow-sm);
    }

    .icon-green { background: var(--success-bg); }
    .icon-red { background: var(--danger-bg); }
    .icon-orange { background: var(--warning-bg); }
    .icon-blue { background: var(--info-bg); }

    .card-content {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .card-label {
        font-size: .8rem;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .card-value {
        font-size: 2.25rem;
        font-weight: 900;
        color: var(--text);
        line-height: 1.1;
        letter-spacing: -.03em;
    }

    .card-green .card-value { color: var(--success); }
    .card-red .card-value { color: var(--danger); }
    .card-orange .card-value { color: var(--warning); }
    .card-blue .card-value { color: var(--info); }

    .card-sub {
        font-size: .78rem;
        color: var(--text-secondary);
    }

    .card-bar {
        margin-top: 16px;
        height: 4px;
        border-radius: 2px;
        background: var(--surface-hover);
        overflow: hidden;
    }

    .bar-fill {
        height: 100%;
        border-radius: 2px;
        transition: width .8s ease;
    }

    .bar-green { background: linear-gradient(90deg, var(--success), #34d399); }
    .bar-red { background: linear-gradient(90deg, var(--danger), #f87171); }
    .bar-orange { background: linear-gradient(90deg, var(--warning), #fbbf24); }

    /* ===== CHART SECTION ===== */
    .chart-section {
        background: var(--surface);
        border-radius: var(--radius-lg);
        padding: 28px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        margin-bottom: 32px;
        animation: fadeSlideUp .5s ease both;
        animation-delay: .3s;
    }

    .bar-chart {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .chart-row {
        display: grid;
        grid-template-columns: 90px 1fr 60px;
        align-items: center;
        gap: 16px;
    }

    .chart-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .9rem;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .chart-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        box-shadow: 0 0 6px currentColor;
    }

    .dot-green { background: var(--success); color: var(--success); }
    .dot-red { background: var(--danger); color: var(--danger); }
    .dot-orange { background: var(--warning); color: var(--warning); }

    .chart-bar-bg {
        height: 28px;
        border-radius: 14px;
        background: var(--bg);
        overflow: hidden;
        position: relative;
    }

    .chart-bar-fill {
        height: 100%;
        border-radius: 14px;
        transition: width 1s ease;
        position: relative;
    }

    .chart-bar-green { background: linear-gradient(90deg, var(--success), #34d399); box-shadow: 0 2px 8px var(--success-glow); }
    .chart-bar-red { background: linear-gradient(90deg, var(--danger), #f87171); box-shadow: 0 2px 8px var(--danger-glow); }
    .chart-bar-orange { background: linear-gradient(90deg, var(--warning), #fbbf24); box-shadow: 0 2px 8px var(--warning-glow); }

    .chart-value {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
        text-align: right;
    }

    /* ===== SECTION TITLE ===== */
    .section-title {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 1.2rem;
        font-weight: 800;
        color: var(--text);
        margin: 0 0 20px 0;
        letter-spacing: -.01em;
    }

    .title-line {
        width: 4px;
        height: 22px;
        border-radius: 2px;
        background: linear-gradient(180deg, var(--primary), var(--primary-dark));
    }

    /* ===== PRODUCT TABLE ===== */
    .product-stats {
        background: var(--surface);
        border-radius: var(--radius-lg);
        padding: 28px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        margin-bottom: 32px;
        animation: fadeSlideUp .5s ease both;
        animation-delay: .35s;
    }

    .table-wrapper {
        overflow-x: auto;
    }

    .stats-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .stats-table th {
        padding: 12px 16px;
        text-align: center;
        font-size: .82rem;
        font-weight: 700;
        color: var(--text-muted);
        border-bottom: 2px solid var(--border);
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .stats-table th:first-child { text-align: center; width: 48px; }
    .stats-table th:nth-child(2) { text-align: left; }

    .th-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: .78rem;
    }

    .th-green { background: var(--success-bg); color: var(--success); }
    .th-red { background: var(--danger-bg); color: var(--danger); }
    .th-orange { background: var(--warning-bg); color: var(--warning); }

    .stats-table td {
